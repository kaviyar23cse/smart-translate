# Example environment variables for the server
# Copy this file to .env and fill values before running the server

# MongoDB connection string (including credentials if needed)
MONGO_URI=mongodb://127.0.0.1:27017/smart-translator
# Optional: specific DB name to use instead of the one in the URI
MONGO_DB=

# JWT secret used to sign authentication tokens (change to a strong secret in production)
JWT_SECRET=your-very-secure-random-secret

# Google Gemini API key for AI summarization and document Q&A
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_KEY

# Optional: choose which Gemini model to use (must be a model your project has quota for)
# Suggested default: gemini-flash-latest (maps to the current Flash model)
GEMINI_MODEL=gemini-flash-latest

# Server port
PORT=5000

# Google Translate API endpoint (uses free gtx client, no API key needed)
# You can replace this with a paid Google Translate API if needed
TRANSLATE_API_URL=https://translate.googleapis.com/translate_a/single
